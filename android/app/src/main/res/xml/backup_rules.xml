<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup rules (API 23+).
  No <include> tags — Android backs up everything by default (including the
  Drift database). We only need to explicitly exclude the flutter_secure_storage
  shared preferences that hold OAuth tokens, which must never be restored
  across devices.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="FlutterSecureStorage"/>
</full-backup-content>
