<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup rules (API 23+).
  Backs up the Drift SQLite database so events survive device resets.
  Excludes the secure-storage shared-preferences that hold OAuth tokens —
  those must not be backed up or restored across devices.
-->
<full-backup-content>
    <!-- Include the Drift database -->
    <include domain="database" path="roots_calendar.db"/>

    <!-- Exclude OAuth tokens stored by flutter_secure_storage -->
    <exclude domain="sharedpref" path="FlutterSecureStorage"/>
</full-backup-content>
