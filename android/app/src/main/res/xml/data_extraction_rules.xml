<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data extraction rules (cloud backup & device-to-device transfer).
  No <include> tags — everything is transferred by default. We only exclude
  the flutter_secure_storage shared preferences that hold OAuth tokens.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="FlutterSecureStorage"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="FlutterSecureStorage"/>
    </device-transfer>
</data-extraction-rules>
