<?xml version="1.0" encoding="utf-8"?>
<!--
  Mirrors the compact variant in roots_day_widget.html:
    header row → divider → event cards (or "No events today")

  RemoteViews constraints:
  - No custom views, no android:fontFamily
  - Card backgrounds use shape drawables (rounded corners)
  - Colors are set programmatically in Kotlin so they match the app theme
  - TextClock updates automatically — no alarm needed
  - System handles widget corner rounding on API 31+
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/widget_bg"
    android:padding="12dp">

    <!-- ── Header row ──────────────────────────────────────────────────── -->
    <!-- [Day num]  [Month · Tree / Date · KEYWORD]  [Clock] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_day_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="@color/widget_accent"
            android:paddingEnd="10dp"
            android:includeFontPadding="false" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_month_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Roots Calendar"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_date_line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textStyle="italic"
                android:textColor="@color/widget_sub"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextClock
                android:id="@+id/widget_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format24Hour="HH:mm"
                android:format12Hour="h:mm a"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/widget_accent"
                android:paddingStart="8dp"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/widget_solar_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/widget_accent"
                android:paddingStart="8dp"
                android:gravity="end"
                android:includeFontPadding="false" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Divider ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/widget_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="7dp"
        android:background="@color/widget_divider"
        android:orientation="horizontal" />

    <!-- ── Event card 1 ────────────────────────────────────────────────── -->
    <!--
      Structure matches .ev / .ev-ad in roots_day_widget.html:
        [3dp coloured bar]  [title (13sp bold) / time (11sp sub)]
      Card background (rounded border) is set programmatically.
    -->
    <LinearLayout
        android:id="@+id/widget_event_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/widget_event_card_light"
        android:visibility="gone">

        <!-- Coloured left bar — background colour set from event.color in Kotlin -->
        <TextView
            android:id="@+id/widget_event_1_bar"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:text=""
            android:background="@color/widget_accent"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_event_1_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_event_1_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/widget_sub"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Event card 2 ────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/widget_event_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="@drawable/widget_event_card_light"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_event_2_bar"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:text=""
            android:background="@color/widget_accent"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_event_2_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_event_2_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/widget_sub"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Event card 3 ────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/widget_event_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/widget_event_card_light"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_event_3_bar"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:text=""
            android:background="@color/widget_accent"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_event_3_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_event_3_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/widget_sub"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Event card 4 ────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/widget_event_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/widget_event_card_light"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_event_4_bar"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:text=""
            android:background="@color/widget_accent"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_event_4_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_event_4_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/widget_sub"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Event card 5 ────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/widget_event_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="@drawable/widget_event_card_light"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_event_5_bar"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:text=""
            android:background="@color/widget_accent"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_event_5_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_event_5_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/widget_sub"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── No events placeholder ──────────────────────────────────────── -->
    <!-- Visible by default so it shows even before the first Flutter update. -->
    <TextView
        android:id="@+id/widget_no_events"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No upcoming events"
        android:textSize="12sp"
        android:textColor="@color/widget_sub"
        android:textStyle="italic"
        android:visibility="visible" />

</LinearLayout>
